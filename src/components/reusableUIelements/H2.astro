---
import { Icon } from 'astro-icon/components';
const { heading, icon } = Astro.props;
---
<div class="flex gap-3 sticky top-0 w-screen -mx-6 px-6 py-5 bg-zinc-900/75 backdrop-blur lg:relative lg:top-auto lg:w-full lg:mx-auto lg:px-0 lg:pb-8 lg:pt-0">
    <Icon name={ icon } class="text-2xl text-green-400" />
    <h2 class="uppercase font-bold text-xl tracking-wider">{ heading }</h2>    
</div>