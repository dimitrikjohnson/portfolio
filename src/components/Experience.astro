---
import H2 from "./reusableUIelements/H2.astro";
import ExperienceEducationCard from "./reusableUIelements/ExperienceEducationCard.astro";
import TitleWithLink from "./reusableUIelements/TitleWithLink.astro";
---
<section id="experience" class="mb-24 lg:mb-32">
    
    <H2 heading="Experience" icon="fa6-solid:briefcase" />    
   
    
    <ul class="mb-14">
        <ExperienceEducationCard
            start="2022"
            end="Present"
            title="Web Developer &#183; UVA's Miller Center"
            description="Build and maintain front-end features for a production Drupal 11 website using JavaScript, SCSS, and Twig, translating \
                stakeholder requirements into accessible and performant user experiences. Manage the website's compliance with WCAG (Web Content \
                Accessibility Guidelines). Collaborate using Git-based workflows, including branching and code reviews. Troubleshoot and debug \
                front-end website issues."
            link="https://millercenter.org/"
            techUsed={
                ["HTML", "SCSS", "JavaScript", "Drupal 10/11", "Twig", "PHP", "Git", "Docker", "AWS", "Jira"]
            }
        />
        <ExperienceEducationCard
            start="2018"
            end="2022"
            title="IST Instructional Assistant &#183; Germanna Community College"
            subtitle="Academic Tutor"
            description="Facilitated Python and Java study group sessions, leading to a 45% increase in student GPA performance. Conducted 100+ tutoring \
                appointments per semester and developed supplemental learning materials for programming courses."
            techUsed={
                ["Python", "Java", "HTML", "CSS", "Google Apps Script"]
            }
        />
    </ul>
    <p class="font-medium text-zinc-200 inline-block">
        <TitleWithLink title={ "View Full Resume" } link={ "../resume.pdf" } />
    </p>
</section>